{
  "$schema": "https://schema.tauri.app/config/2.0.0",
  "productName": "Git Switch",
  "version": "0.5.1",
  "identifier": "dev.avijit.git-switch",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist",
    "removeUnusedCommands": true
  },
  "app": {
    "windows": [
      {
        "title": "Git Switch",
        "width": 1280,
        "height": 800,
        "minWidth": 960,
        "minHeight": 600,
        "titleBarStyle": "Transparent",
        "hiddenTitle": true,
        "dragDropEnabled": true
      }
    ],
    "security": {
      "csp": "default-src 'self' tauri:; connect-src 'self' ipc: http://ipc.localhost https://generativelanguage.googleapis.com; img-src 'self' data: blob: asset: http://asset.localhost; style-src 'self' 'unsafe-inline'; font-src 'self' data:; script-src 'self'"
    },
    "macOSPrivateApi": true
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "DeveloperTool",
    "shortDescription": "Local Git branch manager",
    "longDescription": "A simple, safe local Git branch manager for macOS. Manage branches, pull, commit, and push across multiple repositories.",
    "macOS": {
      "signingIdentity": "-"
    }
  }
}
